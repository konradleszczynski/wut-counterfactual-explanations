# ==============================================================================
# WUT Counterfactual Explanations — .gitignore
# ==============================================================================

# ---- Python bytecode ----
__pycache__/
*.py[codz]
*$py.class
*.so

# ---- Distribution / packaging ----
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- Installer logs ----
pip-log.txt
pip-delete-this-directory.txt

# ---- Unit test / coverage ----
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ---- Translations ----
*.mo
*.pot

# ---- Jupyter Notebook ----
.ipynb_checkpoints/

# ---- IPython ----
profile_default/
ipython_config.py

# ---- Virtual environments ----
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.pixi/
__pypackages__/

# ---- uv ----
# Lock file is committed for reproducibility; cache is not.
.uv_cache/

# ---- IDE & Editors ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Linting / type checking ----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ==============================================================================
# PROJECT-SPECIFIC RULES
# ==============================================================================

# ---- Raw & processed data (downloaded from Kaggle — too large for git) ----
data/*.csv
data/*.zip
data/*.gz
data/*.feather
data/*.parquet
data/*.h5
data/*.hdf5

# ---- Kaggle API credentials (NEVER commit) ----
kaggle.json

# ---- NOTE: Model artifacts (.pkl) are intentionally NOT ignored. ----
# Students must commit their trained model to models/ for reproducibility.
# If your .pkl exceeds 100 MB, consider using Git LFS:
#   git lfs install
#   git lfs track "models/*.pkl"

# ---- PyPI configuration ----
.pypirc
